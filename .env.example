# Database
DATABASE_URL="postgresql://platform:platform@localhost:5432/platform?schema=public"
N8N_DB_URL="postgresql://n8n:n8n@localhost:5432/n8n"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# n8n
N8N_API_URL="http://localhost:5678"
N8N_API_KEY="your-n8n-api-key"
N8N_ENCRYPTION_KEY="generate-32-byte-hex-key"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@infrakt.cloud"

# iDrive E2 (S3-compatible)
E2_ENDPOINT="https://xxxxxx.e2.idrivesync.com"
E2_ACCESS_KEY_ID="your-access-key"
E2_SECRET_ACCESS_KEY="your-secret-key"
E2_BUCKET="free-n8n-backups"
E2_REGION="us-east-1"

# Redis
REDIS_URL="redis://localhost:6379"

# App
PUBLIC_APP_URL="http://localhost:5173"
NODE_ENV="development"
INACTIVITY_DAYS="7"
